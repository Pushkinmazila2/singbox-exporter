{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "sing-box",
  "uid": "singbox-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "sing-box version",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "none",
        "textMode": "name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        }
      },
      "targets": [
        {
          "expr": "singbox_info",
          "legendFormat": "{{version}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory",
      "gridPos": {
        "x": 5,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 52428800
              },
              {
                "color": "red",
                "value": 104857600
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "singbox_memory_bytes",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": {
        "x": 9,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(singbox_connections_active)",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Upload rate (5m)",
      "gridPos": {
        "x": 13,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(singbox_traffic_bytes_total{direction=\"upload\"}[5m])",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Download rate (5m)",
      "gridPos": {
        "x": 17,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(singbox_traffic_bytes_total{direction=\"download\"}[5m])",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Scrape health",
      "gridPos": {
        "x": 21,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "orientation": "vertical"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "singbox_scrape_success",
          "legendFormat": "{{endpoint}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 10,
      "title": "Traffic",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Global traffic (bytes/sec)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "upload"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "download"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "rate(singbox_traffic_bytes_total{direction=\"upload\"}[1m])",
          "legendFormat": "upload"
        },
        {
          "expr": "rate(singbox_traffic_bytes_total{direction=\"download\"}[1m])",
          "legendFormat": "download"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Traffic by outbound (bytes/sec)",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (outbound, direction) (rate(singbox_flow_bytes_total[1m]))",
          "legendFormat": "{{outbound}} {{direction}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 20,
      "title": "Connections",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Active connections by outbound",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (outbound) (singbox_connections_active)",
          "legendFormat": "{{outbound}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Active connections by rule",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (rule_outbound) (singbox_connections_active)",
          "legendFormat": "→ {{rule_outbound}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "bargauge",
      "title": "Active connections — current snapshot",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (outbound, rule_outbound) (singbox_connections_active)",
          "legendFormat": "{{outbound}} | →{{rule_outbound}}",
          "instant": true
        }
      ]
    },
    {
      "id": 24,
      "type": "bargauge",
      "title": "Proxies / outbounds",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "basic",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "singbox_proxy_up",
          "legendFormat": "{{proxy}} ({{type}})",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 30,
      "title": "Connection Log",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 31,
      "type": "logs",
      "title": "Connection events (closed connections)",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{container=\"/singbox-exporter\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
